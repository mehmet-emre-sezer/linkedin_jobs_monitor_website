DATABASE_URL=postgresql+psycopg://jobradar:dev_password@localhost:5432/jobradar_db

# JWT — production'da rastgele uzun bir string ile değiştir
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440
PASSWORD_RESET_EXPIRE_MINUTES=60

# Frontend
FRONTEND_URL=http://localhost:3000

# Production'da Vercel URL'lerini virgülle ekle (dev origin'leri kod içinde zaten var)
# örn. CORS_ORIGINS=https://jobradar.vercel.app,https://www.jobradar.com
CORS_ORIGINS=

# Email — Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Google OAuth (https://console.cloud.google.com → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=

# Telegram bot (BotFather'dan al)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=jobradar_bot
TELEGRAM_WEBHOOK_SECRET=dev-webhook-secret-change-me
TELEGRAM_LINK_EXPIRE_MINUTES=30

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Groq LLM (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Scraper
SEARCH_LOCATION=Istanbul, Turkey
JOBS_PER_QUERY=15
SCORE_THRESHOLD=70
OPTIMIZE_EVERY_N_RUNS=10
# Lokal geliştirme için "mock" — gerçek LinkedIn için "selenium"
SCRAPER_MODE=mock
